#include <stdio.h>

int V, g[20][20], path[20];

int safe(int v, int pos){
    if(g[path[pos-1]][v]==0) return 0;
    for(int i=0;i<pos;i++)
        if(path[i]==v) return 0;
    return 1;
}

int ham(int pos){
    if(pos==V)
        return g[path[pos-1]][path[0]]==1;

    for(int v=1;v<V;v++){
        if(safe(v,pos)){
            path[pos]=v;
            if(ham(pos+1)) return 1;
            path[pos]=-1;
        }
    }
    return 0;
}

int main(){
    scanf("%d",&V);

    for(int i=0;i<V;i++)
        for(int j=0;j<V;j++)
            scanf("%d",&g[i][j]);

    for(int i=0;i<V;i++) path[i]=-1;
    path[0]=0;

    if(!ham(1)){
        printf("Hamiltonian path does not exist");
        return 0;
    }

    for(int i=0;i<V;i++)
        printf("%d ",path[i]);

    printf("%d",path[0]);

    return 0;
}
